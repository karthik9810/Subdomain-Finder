  .badge {{ display: inline-block; padding: .15rem .5rem; border-radius: 4px;
            font-size: .7rem; font-weight: 600; margin-left: .4rem; }}
  .badge.vuln {{ background: #f851491a; color: #f85149; border: 1px solid #f85149; }}
  .s2xx {{ color: #56d364; }} .s3xx {{ color: #e3b341; }}
  .s4xx {{ color: #db6d28; }} .s5xx {{ color: #f85149; }}
  .vuln-section {{ background: #3d1a1a; border: 1px solid #f85149;
                   border-radius: 8px; padding: 1.2rem 1.5rem; margin-bottom: 2rem; }}
  .vuln-section h2 {{ color: #f85149; margin-bottom: 1rem; }}
  .vuln-item {{ background: #0d1117; border-radius: 6px; padding: .8rem 1rem;
                margin-bottom: .8rem; }}
  .vuln-item .sub {{ color: #79c0ff; font-weight: 600; }}
  .vuln-item .detail {{ color: #8b949e; font-size: .82rem; margin-top: .3rem; }}
</style>
</head>
<body>
<h1>🔍 Subdomain Finder PRO</h1>
<p class="meta">Target: <strong>{domain}</strong> &nbsp;|&nbsp; Scanned: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</p>

<div class="stats">
  <div class="stat"><div class="num">{len(found)}</div><div class="lbl">Subdomains Found</div></div>
  <div class="stat {'danger' if vuln_count else ''}">
    <div class="num">{vuln_count}</div><div class="lbl">Takeover Vulns</div>
  </div>
</div>
"""
    if vuln_count:
        html += '<div class="vuln-section"><h2>⚠ Takeover Vulnerabilities</h2>'
        for r in found:
            if r.get("takeover"):
                html += f"""<div class="vuln-item">
  <div class="sub">{r['subdomain']}</div>
  <div class="detail">Service: {r['takeover_service']} &nbsp;|&nbsp; {r['takeover_reason']}</div>
  {'<div class="detail">CNAME: ' + r['cname'] + '</div>' if r.get('cname') else ''}
</div>"""
        html += "</div>"

    html += f"""
<table>
  <thead>
    <tr>
      <th>Subdomain</th><th>IPv4</th><th>IPv6</th><th>CNAME</th>
      <th>HTTP</th><th>Title</th><th>Open Ports</th>
    </tr>
  </thead>
  <tbody>
    {rows}
  </tbody>
</table>
</body></html>"""

    with open(fname, "w") as f:
        f.write(html)
    print(f"  {C.GREEN}✔ HTML report saved → {C.BOLD}{fname}{C.RESET}")


# ═════════════════════════════════════════════════════════════════════
#  MAIN SCAN ORCHESTRATOR
# ═════════════════════════════════════════════════════════════════════
def scan(domain, wordlist, threads=50, http_check=False,
         port_scan=False, output_base=None,
         skip_crtsh=False, skip_axfr=False):

    start_time = time.time()

    print(f"\n  {C.BOLD}{C.WHITE}Target    : {C.CYAN}{domain}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Threads   : {C.CYAN}{threads}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}HTTP Chk  : {C.CYAN}{'Yes' if http_check else 'No'}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Port Scan : {C.CYAN}{'Yes' if port_scan else 'No'}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Started   : {C.CYAN}{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}{C.RESET}")
    sep()

    # ── Wildcard check ───────────────────────────────────────────────
    print(f"\n  {C.YELLOW}[1/5] Wildcard DNS detection...{C.RESET}", end=" ")
    wildcard_ip = detect_wildcard(domain)
    if wildcard_ip:
        print(f"{C.RED}⚠ Wildcard detected ({wildcard_ip}) — false positives will be filtered{C.RESET}")
    else:
        print(f"{C.GREEN}✔ No wildcard{C.RESET}")

    # ── crt.sh ───────────────────────────────────────────────────────
    crtsh_subs = set()
    if not skip_crtsh:
        print(f"  {C.YELLOW}[2/5] Certificate Transparency (crt.sh)...{C.RESET}", end=" ", flush=True)
        crtsh_subs = crtsh_lookup(domain)
        print(f"{C.GREEN}✔ {len(crtsh_subs)} subdomains found{C.RESET}")
    else:
        print(f"  {C.DIM}[2/5] crt.sh skipped{C.RESET}")

    # ── Zone transfer ────────────────────────────────────────────────
    axfr_subs = set()
    ns_list   = []
    if not skip_axfr:
        print(f"  {C.YELLOW}[3/5] DNS Zone Transfer (AXFR)...{C.RESET}", end=" ", flush=True)
        axfr_subs, ns_list = zone_transfer(domain)
        if axfr_subs:
            print(f"{C.RED}⚠ ZONE TRANSFER SUCCEEDED — {len(axfr_subs)} records leaked!{C.RESET}")
        else:
            print(f"{C.GREEN}✔ Zone transfer refused (expected){C.RESET}")
    else:
        print(f"  {C.DIM}[3/5] AXFR skipped{C.RESET}")

    # ── Merge wordlist with discovered subs ──────────────────────────
    extra_subs = set()
    for s in crtsh_subs | axfr_subs:
        prefix = s.replace(f".{domain}", "").replace(domain, "")
        if prefix:
            extra_subs.add(prefix)
    combined = list(dict.fromkeys(wordlist + list(extra_subs)))

    # ── Brute-force DNS ──────────────────────────────────────────────
    print(f"  {C.YELLOW}[4/5] DNS brute-force ({len(combined)} subdomains)...{C.RESET}\n")
    found     = []
    total     = len(combined)
    completed = 0
    lock      = threading.Lock()
    vuln_count = 0

    def worker(sub):
        nonlocal completed, vuln_count
        full, ip, alive = resolve_subdomain(sub, domain, wildcard_ip=wildcard_ip)
        with lock:
            completed += 1
            progress(completed, total, len(found), vuln_count)

        if not alive:
            return

        record = {
            "subdomain": full,
            "ip":        ip,
            "ipv6":      None,
            "cname":     None,
            "status":    None,
            "url":       None,
            "title":     None,
            "ports":     [],
            "takeover":  False,
            "takeover_service": None,
            "takeover_reason":  None,
        }

        # IPv6
        record["ipv6"] = resolve_ipv6(full)

        # CNAME
        record["cname"] = get_cname(full)

        # HTTP
        http_body = ""
        if http_check:
            sc, url, title = check_http(full)
            record["status"] = sc
            record["url"]    = url
            record["title"]  = title
            if url:
                try:
                    r = requests.get(url, timeout=4, headers={"User-Agent": "Mozilla/5.0"})
                    http_body = r.text
                except Exception:
                    pass

        # Port scan
        if port_scan and ip:
            record["ports"] = scan_ports(ip)

        # Takeover check
        vuln, svc, reason = check_takeover(full, record["cname"], http_body)
        if vuln:
            record["takeover"]         = True
            record["takeover_service"] = svc
            record["takeover_reason"]  = reason
            with lock:
                vuln_count += 1

        with lock:
            found.append(record)

    with ThreadPoolExecutor(max_workers=threads) as executor:
        futures = [executor.submit(worker, sub) for sub in combined]
        for _ in as_completed(futures):
            pass

    elapsed = time.time() - start_time
    print(f"\n\n  {C.GREEN}✔ Scan complete in {elapsed:.1f}s{C.RESET}\n")

    # ── TXT records ──────────────────────────────────────────────────
    print(f"  {C.YELLOW}[5/5] Fetching TXT/SPF records for root domain...{C.RESET}", end=" ")
    txt_records = get_txt_records(domain)
    print(f"{C.GREEN}✔ {len(txt_records)} TXT records{C.RESET}")

    sep()

    # ── Print results ────────────────────────────────────────────────
    if found:
        print(f"\n  {C.BOLD}{C.GREEN}FOUND {len(found)} SUBDOMAINS:{C.RESET}\n")
        for i, r in enumerate(found, 1):
            sc    = r["status"]
            color = status_color(sc)
            sc_str = f"{color}[{sc}]{C.RESET}" if sc else f"{C.DIM}[DNS]{C.RESET}"
            vuln_tag = f"  {C.RED}{C.BOLD}⚠ TAKEOVER({r['takeover_service']}){C.RESET}" if r["takeover"] else ""
            print(f"  {C.DIM}[{i:03d}]{C.RESET}  {C.CYAN}{r['subdomain']:<42}{C.RESET}  "
                  f"{C.YELLOW}{r['ip']:<18}{C.RESET}  {sc_str}{vuln_tag}")
    else:
        print(f"\n  {C.YELLOW}No subdomains found.{C.RESET}")

    # ── Vulnerability summary ────────────────────────────────────────
    if vuln_count:
        sep("═")
        print(f"\n  {C.RED}{C.BOLD}⚠  {vuln_count} SUBDOMAIN TAKEOVER VULNERABILITY(IES) DETECTED{C.RESET}\n")
        for r in found:
            if r["takeover"]:
                print(f"  {C.RED}►{C.RESET} {C.CYAN}{r['subdomain']}{C.RESET}")
                print(f"    Service : {C.YELLOW}{r['takeover_service']}{C.RESET}")
                print(f"    Reason  : {r['takeover_reason']}")
                if r["cname"]:
                    print(f"    CNAME   : {C.DIM}{r['cname']}{C.RESET}")
                print()
        print(f"  {C.YELLOW}Remediation: Remove or update the dangling DNS record.{C.RESET}\n")
        sep("═")

    # ── AXFR warning ─────────────────────────────────────────────────
    if axfr_subs:
        print(f"\n  {C.RED}{C.BOLD}⚠  DNS ZONE TRANSFER IS ENABLED — THIS IS A MISCONFIGURATION!{C.RESET}")
        print(f"  {C.YELLOW}   Restrict AXFR to authorised nameservers only.{C.RESET}\n")

    # ── TXT records display ──────────────────────────────────────────
    if txt_records:
        sep()
        print(f"\n  {C.BOLD}TXT / SPF Records for {domain}:{C.RESET}")
        for t in txt_records:
            print(f"  {C.DIM}•{C.RESET} {t}")

    sep()
    print(f"\n  {C.BOLD}SUMMARY{C.RESET}")
    print(f"  Checked        : {C.CYAN}{total}{C.RESET}")
    print(f"  Subdomains     : {C.GREEN}{len(found)}{C.RESET}")
    print(f"  Vulnerabilities: {C.RED if vuln_count else C.GREEN}{vuln_count}{C.RESET}")
    print(f"  AXFR Exposed   : {C.RED + 'YES ⚠' if axfr_subs else C.GREEN + 'No'}{C.RESET}")
    print(f"  Elapsed        : {C.CYAN}{elapsed:.1f}s{C.RESET}\n")

    # ── Save reports ─────────────────────────────────────────────────
    if output_base and found:
        sep()
        print()
        save_txt(domain, found, output_base)
        save_json(domain, found, output_base)
        save_html(domain, found, output_base)
        print()

    return found


# ═════════════════════════════════════════════════════════════════════
#  INTERACTIVE MODE
# ═════════════════════════════════════════════════════════════════════
def interactive_mode():
    print_banner()

    print(f"  {C.BOLD}{C.WHITE}ENTER TARGET DOMAIN{C.RESET}")
    print(f"  {C.DIM}Example: example.com{C.RESET}\n")
    raw = input(f"  {C.YELLOW}>> Domain: {C.RESET}").strip()
    if not raw:
        print(f"  {C.RED}No domain entered.{C.RESET}"); sys.exit(0)
    domain = clean_domain(raw)
    print(f"  {C.GREEN}✔ Target: {domain}{C.RESET}\n")

    # Wordlist
    print(f"  {C.BOLD}WORDLIST{C.RESET}")
    print(f"  1. Built-in ({len(WORDLIST)} subdomains)")
    print(f"  2. Custom file")
    wl = input(f"\n  {C.YELLOW}>> Choice (1/2): {C.RESET}").strip()
    if wl == "2":
        path = input(f"  {C.YELLOW}>> Path: {C.RESET}").strip()
        if not os.path.exists(path):
            print(f"  {C.RED}File not found.{C.RESET}"); sys.exit(1)
        with open(path) as f:
            wordlist = [l.strip() for l in f if l.strip()]
        print(f"  {C.GREEN}✔ Loaded {len(wordlist)} words{C.RESET}")
    else:
        wordlist = WORDLIST

    # Modules
    print(f"\n  {C.BOLD}OPTIONAL MODULES{C.RESET}")
    http_ans = input(f"  {C.YELLOW}>> HTTP status check? (y/n): {C.RESET}").strip().lower()
    http_check = http_ans == "y"

    port_ans = input(f"  {C.YELLOW}>> Port scan discovered hosts? (y/n): {C.RESET}").strip().lower()
    port_scan = port_ans == "y"

    # Save
    print(f"\n  {C.BOLD}OUTPUT{C.RESET}")
    save_ans = input(f"  {C.YELLOW}>> Save report (TXT + JSON + HTML)? (y/n): {C.RESET}").strip().lower()
    output_base = None
    if save_ans == "y":
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_base = f"subdomains_{domain}_{ts}"
        print(f"  {C.GREEN}✔ Will save as {output_base}.*{C.RESET}")

    # Threads
    t_input = input(f"\n  {C.YELLOW}>> Threads (Enter = 50): {C.RESET}").strip()
    threads = int(t_input) if t_input.isdigit() else 50

    scan(domain, wordlist, threads=threads, http_check=http_check,
         port_scan=port_scan, output_base=output_base)


# ═════════════════════════════════════════════════════════════════════
#  CLI MODE
# ═════════════════════════════════════════════════════════════════════
def main():
    parser = argparse.ArgumentParser(
        description="Subdomain Finder PRO — Enumeration & Vulnerability Scanner",
        epilog="Example: python subdomain_finder_pro.py --domain example.com --http --ports --save"
    )
    parser.add_argument("--domain",    help="Target domain")
    parser.add_argument("--wordlist",  help="Custom wordlist path")
    parser.add_argument("--threads",   type=int, default=50, help="Threads (default: 50)")
    parser.add_argument("--http",      action="store_true", help="HTTP status check")
    parser.add_argument("--ports",     action="store_true", help="Port scan discovered hosts")
    parser.add_argument("--save",      action="store_true", help="Save TXT/JSON/HTML reports")
    parser.add_argument("--output",    help="Output base filename")
    parser.add_argument("--no-crtsh",  action="store_true", help="Skip crt.sh lookup")
    parser.add_argument("--no-axfr",   action="store_true", help="Skip zone transfer attempt")
    args = parser.parse_args()

    if not args.domain:
        interactive_mode()
        return

    print_banner()
    domain   = clean_domain(args.domain)
    wordlist = WORDLIST
    if args.wordlist:
        with open(args.wordlist) as f:
            wordlist = [l.strip() for l in f if l.strip()]

    output_base = None
    if args.save:
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_base = args.output or f"subdomains_{domain}_{ts}"

    scan(domain, wordlist, threads=args.threads,
         http_check=args.http, port_scan=args.ports,
         output_base=output_base,
         skip_crtsh=args.no_crtsh, skip_axfr=args.no_axfr)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n\n  {C.YELLOW}Scan interrupted.{C.RESET}\n")
        sys.exit(0)
