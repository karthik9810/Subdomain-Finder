#  PHASE 0 — WILDCARD DETECTION
# ═════════════════════════════════════════════════════════════════════
def detect_wildcard(domain):
    """Resolve a random non-existent subdomain. If it resolves, wildcard DNS is active."""
    test = f"{random_str()}.{domain}"
    try:
        socket.setdefaulttimeout(3)
        ip = socket.gethostbyname(test)
        return ip  # wildcard IP
    except (socket.gaierror, socket.timeout):
        return None


# ═════════════════════════════════════════════════════════════════════
#  PHASE 1 — CERTIFICATE TRANSPARENCY (crt.sh)
# ═════════════════════════════════════════════════════════════════════
def crtsh_lookup(domain):
    """Query crt.sh for subdomains via Certificate Transparency logs."""
    found = set()
    if not REQUESTS_OK:
        return found
    try:
        url = f"https://crt.sh/?q=%25.{domain}&output=json"
        r = requests.get(url, timeout=15, headers={"User-Agent": "SubdomainFinderPro/2.0"})
        if r.status_code == 200:
            data = r.json()
            for entry in data:
                name = entry.get("name_value", "")
                for sub in name.splitlines():
                    sub = sub.strip().lstrip("*.")
                    if sub.endswith(f".{domain}") or sub == domain:
                        found.add(sub.lower())
    except Exception:
        pass
    return found


# ═════════════════════════════════════════════════════════════════════
#  PHASE 2 — DNS ZONE TRANSFER (AXFR)
# ═════════════════════════════════════════════════════════════════════
def zone_transfer(domain):
    """Attempt AXFR zone transfer against all nameservers."""
    found = set()
    if not DNSPYTHON_OK:
        return found, []
    ns_list = []
    try:
        answers = dns.resolver.resolve(domain, "NS")
        ns_list = [str(r.target).rstrip(".") for r in answers]
    except Exception:
        return found, ns_list

    for ns in ns_list:
        try:
            z = dns.zone.from_xfr(dns.query.xfr(ns, domain, timeout=5))
            for name in z.nodes.keys():
                record = str(name)
                if record != "@":
                    found.add(f"{record}.{domain}")
        except Exception:
            pass
    return found, ns_list


# ═════════════════════════════════════════════════════════════════════
#  PHASE 3 — DNS RESOLUTION
# ═════════════════════════════════════════════════════════════════════
def resolve_subdomain(subdomain, domain, timeout=2, wildcard_ip=None):
    full = f"{subdomain}.{domain}"
    try:
        socket.setdefaulttimeout(timeout)
        ip = socket.gethostbyname(full)
        if wildcard_ip and ip == wildcard_ip:
            return (full, None, False)  # filter wildcard false-positives
        return (full, ip, True)
    except (socket.gaierror, socket.timeout):
        return (full, None, False)

def resolve_ipv6(full_domain):
    if not DNSPYTHON_OK:
        return None
    try:
        answers = dns.resolver.resolve(full_domain, "AAAA")
        return str(answers[0])
    except Exception:
        return None

def get_cname(full_domain):
    if not DNSPYTHON_OK:
        return None
    try:
        answers = dns.resolver.resolve(full_domain, "CNAME")
        return str(answers[0].target).rstrip(".")
    except Exception:
        return None

def get_txt_records(domain):
    if not DNSPYTHON_OK:
        return []
    try:
        answers = dns.resolver.resolve(domain, "TXT")
        return [str(r) for r in answers]
    except Exception:
        return []


# ═════════════════════════════════════════════════════════════════════
#  PHASE 4 — HTTP CHECK
# ═════════════════════════════════════════════════════════════════════
def check_http(full_domain, timeout=4):
    if not REQUESTS_OK:
        return None, None, None
    for scheme in ["https", "http"]:
        try:
            url = f"{scheme}://{full_domain}"
            r = requests.get(url, timeout=timeout, allow_redirects=True,
                             headers={"User-Agent": "Mozilla/5.0 (SubdomainFinderPro)"})
            title = ""
            if "<title>" in r.text.lower():
                start = r.text.lower().find("<title>") + 7
                end   = r.text.lower().find("</title>", start)
                title = r.text[start:end].strip()[:60] if end > start else ""
            return r.status_code, url, title
        except Exception:
            continue
    return None, None, None


# ═════════════════════════════════════════════════════════════════════
#  PHASE 5 — SUBDOMAIN TAKEOVER DETECTION
# ═════════════════════════════════════════════════════════════════════
def check_takeover(full_domain, cname=None, http_body=""):
    """
    Check for subdomain takeover vulnerability.
    Returns (vulnerable: bool, service: str, reason: str)
    """
    for service, cname_kw, body_fp in TAKEOVER_SIGS:
        # CNAME-based detection
        if cname and cname_kw.lower() in cname.lower():
            if body_fp.lower() in http_body.lower():
                return True, service, f"CNAME → {cname} | Body fingerprint matched"
        # Body-only detection (no CNAME needed)
        elif not cname_kw and body_fp.lower() in http_body.lower():
            return True, service, "Body fingerprint matched"
    return False, None, None


