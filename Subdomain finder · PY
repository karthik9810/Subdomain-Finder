# ─── Clean Domain Input ───────────────────────────────────────
def clean_domain(domain):
    domain = domain.strip()
    domain = domain.replace("https://", "").replace("http://", "")
    domain = domain.replace("www.", "")
    domain = domain.split("/")[0]
    return domain.lower()
 
# ─── DNS Resolve ──────────────────────────────────────────────
def resolve_subdomain(subdomain, domain, timeout=2):
    full = f"{subdomain}.{domain}"
    try:
        socket.setdefaulttimeout(timeout)
        ip = socket.gethostbyname(full)
        return (full, ip, True)
    except (socket.gaierror, socket.timeout):
        return (full, None, False)
 
# ─── HTTP Status Check ────────────────────────────────────────
def check_http(full_domain, timeout=3):
    if not REQUESTS_AVAILABLE:
        return None, None
    for scheme in ["https", "http"]:
        try:
            url = f"{scheme}://{full_domain}"
            r = requests.get(url, timeout=timeout, allow_redirects=True,
                             headers={"User-Agent": "Mozilla/5.0"})
            return r.status_code, url
        except Exception:
            continue
    return None, None
 
# ─── Status Color ─────────────────────────────────────────────
def status_color(code):
    if code is None:
        return C.DIM
    if 200 <= code < 300:
        return C.GREEN
    if 300 <= code < 400:
        return C.YELLOW
    if 400 <= code < 500:
        return C.MAGENTA
    return C.RED
 
# ─── Separator ────────────────────────────────────────────────
def sep():
    print(f"  {C.DIM}{'─' * 65}{C.RESET}")
 
# ─── Progress Bar ─────────────────────────────────────────────
def progress(current, total, found):
    pct  = int((current / total) * 40)
    bar  = f"{C.GREEN}{'█' * pct}{C.DIM}{'░' * (40 - pct)}{C.RESET}"
    print(f"\r  [{bar}] {C.CYAN}{current}/{total}{C.RESET}  Found: {C.GREEN}{found}{C.RESET}  ", end="", flush=True)
 
# ─── Main Scan ────────────────────────────────────────────────
def scan(domain, wordlist, threads=50, http_check=False, output_file=None):
    found     = []
    total     = len(wordlist)
    completed = 0
    lock      = threading.Lock()
 
    print(f"\n  {C.BOLD}{C.WHITE}Target   : {C.CYAN}{domain}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Wordlist : {C.CYAN}{total} subdomains{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Threads  : {C.CYAN}{threads}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}HTTP Chk : {C.CYAN}{'Yes' if http_check else 'No'}{C.RESET}")
    print(f"  {C.BOLD}{C.WHITE}Started  : {C.CYAN}{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}{C.RESET}")
    sep()
    print(f"\n  {C.YELLOW}Scanning...{C.RESET}\n")
 
    def worker(sub):
        nonlocal completed
        full, ip, alive = resolve_subdomain(sub, domain)
        with lock:
            completed += 1
            progress(completed, total, len(found))
        if alive:
            status_code = None
            url         = None
            if http_check:
                status_code, url = check_http(full)
            with lock:
                found.append({
                    "subdomain": full,
                    "ip":        ip,
                    "status":    status_code,
                    "url":       url,
                })
        return None
 
    with ThreadPoolExecutor(max_workers=threads) as executor:
        futures = [executor.submit(worker, sub) for sub in wordlist]
        for _ in as_completed(futures):
            pass
 
    print(f"\n\n  {C.GREEN}✔ Scan complete!{C.RESET}\n")
    sep()
 
    # ─── Print Results ────────────────────────────────────────
    if found:
        print(f"\n  {C.BOLD}{C.GREEN}FOUND {len(found)} SUBDOMAINS:{C.RESET}\n")
        for i, item in enumerate(found, 1):
            sc    = item["status"]
            color = status_color(sc)
            sc_str = f"{color}[{sc}]{C.RESET}" if sc else f"{C.DIM}[DNS]{C.RESET}"
            print(f"  {C.DIM}[{i:03d}]{C.RESET}  {C.CYAN}{item['subdomain']:<40}{C.RESET}  "
                  f"{C.YELLOW}{item['ip']:<18}{C.RESET}  {sc_str}")
    else:
        print(f"\n  {C.YELLOW}No subdomains found. Try a larger wordlist.{C.RESET}")
 
    sep()
 
    # ─── Summary ─────────────────────────────────────────────
    print(f"\n  {C.BOLD}SUMMARY{C.RESET}")
    print(f"  Total Checked : {C.CYAN}{total}{C.RESET}")
    print(f"  Found         : {C.GREEN}{len(found)}{C.RESET}")
    print(f"  Not Found     : {C.DIM}{total - len(found)}{C.RESET}")
 
    # ─── Save Results ─────────────────────────────────────────
    if output_file and found:
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        fname = output_file or f"subdomains_{domain}_{timestamp}.txt"
 
        # Save TXT
        txt_file = fname.replace(".json", "") + ".txt"
        with open(txt_file, "w") as f:
            f.write(f"# Subdomain Finder Results\n")
            f.write(f"# Target  : {domain}\n")
            f.write(f"# Date    : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"# Found   : {len(found)}\n\n")
            for item in found:
                f.write(f"{item['subdomain']} | {item['ip']} | {item['status']}\n")
        print(f"\n  {C.GREEN}✔ Saved to {C.BOLD}{txt_file}{C.RESET}")
 
        # Save JSON
        json_file = fname.replace(".txt", "") + ".json"
        with open(json_file, "w") as f:
            json.dump({
                "target": domain,
                "date": datetime.now().isoformat(),
                "found": len(found),
                "results": found
            }, f, indent=2)
        print(f"  {C.GREEN}✔ Saved to {C.BOLD}{json_file}{C.RESET}")
 
    return found
 
# ─── Custom Wordlist Loader ───────────────────────────────────
def load_wordlist(path):
    if not os.path.exists(path):
        print(f"  {C.RED}File not found: {path}{C.RESET}")
        sys.exit(1)
    with open(path) as f:
        words = [line.strip() for line in f if line.strip()]
    print(f"  {C.GREEN}✔ Loaded {len(words)} words from {path}{C.RESET}")
    return words
 
