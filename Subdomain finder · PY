    domain = clean_domain(raw)
    print(f"  {C.GREEN}✔ Target set to: {domain}{C.RESET}\n")
 
    # Custom wordlist?
    print(f"  {C.BOLD}{C.WHITE}WORDLIST{C.RESET}")
    print(f"  1. Use built-in wordlist ({len(WORDLIST)} subdomains)")
    print(f"  2. Load custom wordlist from file")
    wl_choice = input(f"\n  {C.YELLOW}>> Choice (1/2): {C.RESET}").strip()
    if wl_choice == "2":
        path = input(f"  {C.YELLOW}>> File path: {C.RESET}").strip()
        wordlist = load_wordlist(path)
    else:
        wordlist = WORDLIST
 
    # HTTP check?
    print(f"\n  {C.BOLD}{C.WHITE}HTTP STATUS CHECK{C.RESET}")
    print(f"  {C.DIM}Check if subdomains respond to HTTP/HTTPS? (slower but more info){C.RESET}")
    http_ans = input(f"\n  {C.YELLOW}>> Enable HTTP check? (y/n): {C.RESET}").strip().lower()
    http_check = http_ans == "y"
 
    if http_check and not REQUESTS_AVAILABLE:
        print(f"  {C.YELLOW}⚠ 'requests' not installed. Run: pip install requests{C.RESET}")
        http_check = False
 
    # Save output?
    print(f"\n  {C.BOLD}{C.WHITE}SAVE RESULTS{C.RESET}")
    save_ans = input(f"  {C.YELLOW}>> Save results to file? (y/n): {C.RESET}").strip().lower()
    output_file = None
    if save_ans == "y":
        timestamp  = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_file = f"subdomains_{domain}_{timestamp}"
        print(f"  {C.GREEN}✔ Results will be saved as {output_file}.txt / .json{C.RESET}")
 
    # Threads
    print(f"\n  {C.BOLD}{C.WHITE}THREADS (default: 50){C.RESET}")
    t_input = input(f"  {C.YELLOW}>> Threads (press Enter for 50): {C.RESET}").strip()
    threads = int(t_input) if t_input.isdigit() else 50
 
    # Run scan
    scan(domain, wordlist, threads=threads, http_check=http_check, output_file=output_file)
 
# ─── CLI Mode ─────────────────────────────────────────────────
def cli_mode(args):
    domain = clean_domain(args.domain)
    wordlist = load_wordlist(args.wordlist) if args.wordlist else WORDLIST
 
    if args.http and not REQUESTS_AVAILABLE:
        print(f"  {C.YELLOW}⚠ Install requests: pip install requests{C.RESET}")
        args.http = False
 
    output_file = args.output or f"subdomains_{domain}_{datetime.now().strftime('%Y%m%d_%H%M%S')}" if args.save else None
    scan(domain, wordlist, threads=args.threads, http_check=args.http, output_file=output_file)
 
# ─── Entry Point ──────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        description="Subdomain Finder - Subdomain Enumeration Tool",
        epilog="Example: python subdomain_finder.py --domain example.com --http --save"
    )
    parser.add_argument("--domain",   help="Target domain (e.g. example.com)")
    parser.add_argument("--wordlist", help="Path to custom wordlist file")
    parser.add_argument("--threads",  type=int, default=50, help="Number of threads (default: 50)")
    parser.add_argument("--http",     action="store_true", help="Enable HTTP status check")
    parser.add_argument("--save",     action="store_true", help="Save results to file")
    parser.add_argument("--output",   help="Output filename (without extension)")
 
    args = parser.parse_args()
 
    if args.domain:
        print_banner()
        cli_mode(args)
    else:
        interactive_mode()
 
if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n\n  {C.YELLOW}Scan interrupted by user.{C.RESET}\n")
        sys.exit(0)
 
